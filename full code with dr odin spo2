def _normalize_mac(addr):
    return (addr or "").strip().upper()

def _is_bp_device(dev):
    if not dev:
        return False
    if _normalize_mac(dev.address) == _normalize_mac(BP_ALLOWED_MAC):
        return True
    if dev.name and any(h in dev.name.upper() for h in BP_NAME_HINTS):
        return True
    return False

def _is_spo2_device(dev):
    if not dev:
        return False
    if _normalize_mac(dev.address) == _normalize_mac(SPO2_ALLOWED_MAC):
        return True
    if dev.name and any(h in dev.name.upper() for h in SPO2_NAME_HINTS):
        return True
    return False

def _is_glucose_device(dev):
    if not dev:
        return False
    if _normalize_mac(dev.address) == _normalize_mac(GLUCOSE_ALLOWED_MAC):
        return True
    if dev.name and any(h in dev.name.upper() for h in GLUCOSE_NAME_HINTS):
        return True
    return False

async def scan_known_devices(timeout=SCAN_TIMEOUT):
    found_bp   = None
    found_spo2 = None
    found_gluc = None
    try:
        devices = await BleakScanner.discover(timeout=timeout, return_adv=False)
    except Exception as e:
        print(f"  [BLE] Scan failed: {type(e).__name__}: {e}")
        return None, None, None
    for dev in devices:
        if BLE_DEBUG_LOG:
            print(f"  [BLE seen] {dev.name or '(unnamed)'} @ {dev.address}")
        if _is_bp_device(dev):
            found_bp = dev
            print(f"  [BLE match] BP candidate: {dev.name or '(unnamed)'} @ {dev.address}")
        if _is_spo2_device(dev):
            found_spo2 = dev
            print(f"  [BLE match] SpO2 candidate: {dev.name or '(unnamed)'} @ {dev.address}")
        if _is_glucose_device(dev):
            found_gluc = dev
            print(f"  [BLE match] Glucose candidate: {dev.name or '(unnamed)'} @ {dev.address}")
    return found_bp, found_spo2, found_gluc

async def scan_for_specific_device(kind: str, timeout: int, leds=None):
    print(f"  [{kind}] Scanning up to {timeout}s for connection...")

    def _set_active(k, active):
        if leds:
            if k == "BP":
                leds.set_bp_active(active)
            elif k == "SpO2":
                leds.set_spo2_active(active)
            elif k == "Glucose":
                leds.set_gluc_active(active)

    try:
        _set_active(kind, True)
        start = time.monotonic()
        while time.monotonic() - start < timeout:
            remaining    = timeout - (time.monotonic() - start)
            pass_timeout = min(5, max(2, remaining))
            bp_dev, spo2_dev, gluc_dev = await scan_known_devices(timeout=pass_timeout)
            if kind == "BP" and bp_dev:
                print(f"  [BP] Found during secondary scan: {bp_dev.name or '(unnamed)'} @ {bp_dev.address}")
                return bp_dev
            if kind == "SpO2" and spo2_dev:
                print(f"  [SpO2] Found during secondary scan: {spo2_dev.name or '(unnamed)'} @ {spo2_dev.address}")
                return spo2_dev
            if kind == "Glucose" and gluc_dev:
                print(f"  [Glucose] Found during secondary scan: {gluc_dev.name or '(unnamed)'} @ {gluc_dev.address}")
                return gluc_dev
            await asyncio.sleep(0.5)
        print(f"  [{kind}] Not found within {timeout}s — skipping {kind}.")
        return None
    finally:
        _set_active(kind, False)

async def wait_for_patient_device():
    print("\n>>> WAITING FOR PATIENT — power on BP cuff, SpO2, or Glucose meter to begin <<<\n")
    last_print = time.time()
    started    = time.time()
    while True:
        bp_dev, spo2_dev, gluc_dev = await scan_known_devices(timeout=SCAN_TIMEOUT)
        if bp_dev:
            print(f"  ✓ Patient trigger detected from BP: {bp_dev.name or '(unnamed)'} @ {bp_dev.address}")
            return "BP", bp_dev
        if spo2_dev:
            print(f"  ✓ Patient trigger detected from SpO2: {spo2_dev.name or '(unnamed)'} @ {spo2_dev.address}")
            return "SpO2", spo2_dev
        if gluc_dev:
            print(f"  ✓ Patient trigger detected from Glucose: {gluc_dev.name or '(unnamed)'} @ {gluc_dev.address}")
            return "Glucose", gluc_dev
        now = time.time()
        if now - last_print >= PATIENT_IDLE_PRINT_EVERY:
            print(f"  ... still waiting ({int((now - started) / 60)} min elapsed)")
            last_print = now
        await asyncio.sleep(2)

