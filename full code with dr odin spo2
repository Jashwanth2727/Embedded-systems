def sfloat_to_float(raw):
    mantissa = raw & 0x0FFF
    exponent = raw >> 12
    if exponent >= 0x8:
        exponent -= 0x10
    if mantissa >= 0x0800:
        mantissa -= 0x1000
    if mantissa == 0x07FF:
        return None
    return mantissa * (10 ** exponent)

def parse_glucose_measurement(data: bytearray):
    offset = 0
    flags = data[offset]
    offset += 1

    time_offset_present    = bool(flags & 0x01)
    glucose_present        = bool(flags & 0x02)
    unit_mol_per_l         = bool(flags & 0x04)
    sensor_status_present  = bool(flags & 0x08)
    context_follows        = bool(flags & 0x10)

    seq_number = struct.unpack_from("<H", data, offset)[0]
    offset += 2

    year, month, day, hour, minute, second = struct.unpack_from("<HBBBBB", data, offset)
    offset += 7
    timestamp = datetime(year, month, day, hour, minute, second)

    result = {
        "sequence_number": seq_number,
        "timestamp": timestamp,
        "context_follows": context_follows,
    }

    if time_offset_present:
        result["time_offset_minutes"] = struct.unpack_from("<h", data, offset)[0]
        offset += 2

    if glucose_present:
        raw = struct.unpack_from("<H", data, offset)[0]
        offset += 2
        value = sfloat_to_float(raw)
        unit = "mol/L" if unit_mol_per_l else "kg/L"
        mg_dl = value * 100000 if (value is not None and not unit_mol_per_l) else None
        result["glucose_value_raw"] = value
        result["unit"] = unit
        result["glucose_mg_dl"] = mg_dl

        type_loc = data[offset]
        offset += 1
        result["sample_type"] = type_loc >> 4
        result["sample_location"] = type_loc & 0x0F

    if sensor_status_present:
        result["sensor_status"] = struct.unpack_from("<H", data, offset)[0]
        offset += 2

    return result

class GlucoseSession:
    def __init__(self, leds=None):
        self.leds     = leds
        self.readings = []
        self.done     = asyncio.Event()

    def _meas_handler(self, sender, data: bytearray):
        try:
            reading = parse_glucose_measurement(data)
            self.readings.append(reading)
            print(f"  [Glucose] mg/dL={reading.get('glucose_mg_dl')} seq={reading.get('sequence_number')}")
        except Exception as e:
            print(f"  [Glucose] Parse error: {type(e).__name__}: {e}")

    def _racp_handler(self, sender, data: bytearray):
        print(f"  [Glucose] RACP response: {data.hex()}")
        self.done.set()

    async def run(self, device):
        if not device:
            print("  [Glucose] No glucose device available — skipping.")
            return None
        if self.leds:
            self.leds.set_gluc_active(True)
        try:
            async with BleakClient(device, timeout=GLUCOSE_CONNECT_TIMEOUT) as client:
                print("  [Glucose] Connected ✓")

                glucose_service = client.services.get_service(GLUCOSE_SERVICE_UUID)
                if not glucose_service:
                    print("  [Glucose] Service not found on device.")
                    return None

                meas_char = glucose_service.get_characteristic(GLUCOSE_MEASUREMENT_UUID)
                racp_char = glucose_service.get_characteristic(RACP_UUID)

                await client.start_notify(meas_char, self._meas_handler)
                await client.start_notify(racp_char, self._racp_handler)

                print("  [Glucose] Requesting all stored records...")
                await client.write_gatt_char(racp_char, bytearray([0x01, 0x01]), response=True)

                try:
                    await asyncio.wait_for(self.done.wait(), timeout=GLUCOSE_STREAM_WAIT_SECS)
                except asyncio.TimeoutError:
                    print("  [Glucose] ⚠ RACP response timeout — using readings collected so far.")

                try:
                    await client.stop_notify(meas_char)
                    await client.stop_notify(racp_char)
                except Exception:
                    pass
        except Exception as e:
            print(f"  [Glucose] Connection/measurement failed: {type(e).__name__}: {e}")
            return None
        finally:
            if self.leds:
                self.leds.set_gluc_active(False)

        if not self.readings:
            print("  [Glucose] No readings captured.")
            return None

        latest = max(self.readings, key=lambda r: r.get("sequence_number", 0))
        result = {
            "mg_dl":           latest.get("glucose_mg_dl"),
            "timestamp":       latest["timestamp"].isoformat() if latest.get("timestamp") else None,
            "sample_type":     latest.get("sample_type"),
            "sample_location": latest.get("sample_location"),
        }
        print(f"  ✓ Glucose: {result['mg_dl']} mg/dL @ {result['timestamp']}")
        return result

