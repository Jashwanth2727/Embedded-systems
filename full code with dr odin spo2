async def record_video(patient_num: int, leds):
    date_str = datetime.now().strftime("%Y-%m-%d")
    time_str = datetime.now().strftime("%H%M%S")

    main_folder = VIDEO_BASE_DIR / date_str
    main_folder.mkdir(parents=True, exist_ok=True)

    filename = f"patient{patient_num}_{time_str}.mp4"
    out_path = main_folder / filename

    cmd = [
        "ffmpeg", "-y", "-f", "v4l2", "-input_format", "mjpeg",
        "-video_size", "1920x1080", "-framerate", "30",
        "-i", CAMERA_DEVICE,
        "-t", str(CAMERA_RECORD_SECS),
        "-vcodec", "copy",
        str(out_path),
    ]

    print(f"\n  [Camera] Recording {CAMERA_RECORD_SECS}s -> {out_path}")
    try:
        proc = await asyncio.create_subprocess_exec(
            *cmd,
            stdout=asyncio.subprocess.DEVNULL,
            stderr=asyncio.subprocess.PIPE,
        )
        _, stderr = await asyncio.wait_for(
            proc.communicate(), timeout=CAMERA_RECORD_SECS + 10
        )
        if proc.returncode == 0:
            print(f"  [Camera] ✓ Saved: {out_path}")
        else:
            err = stderr.decode(errors="replace").strip().splitlines()
            print(f"  [Camera] ffmpeg error (rc={proc.returncode}): "
                  f"{err[-1] if err else '(no output)'}")
            return None
    except Exception as e:
        print(f"  [Camera] Error: {type(e).__name__}: {e}")
        return None

    return out_path

# ---------------------------------------------------------------------------
# Patient capture
# ---------------------------------------------------------------------------

_SESSION_CLASSES = {
    "BP":      BPSession,
    "SpO2":    SpO2Session,
    "Glucose": GlucoseSession,
}
_SESSION_TIMEOUTS = {
    "BP":      BP_MEASURE_TIMEOUT,
    "SpO2":    SPO2_MEASURE_TIMEOUT,
    "Glucose": GLUCOSE_CONNECT_TIMEOUT + GLUCOSE_STREAM_WAIT_SECS,
}

async def run_patient_capture(patient_num, trigger_kind, trigger_device, temp_sensor, leds):
    session_started_at = datetime.now()
    print(f"\n{'#' * 60}")
    print(f"# PATIENT #{patient_num} @ {session_started_at.strftime('%Y-%m-%d %H:%M:%S')}")
    print('#' * 60)
    record_base = {
        "kiosk_id":    KIOSK_ID,
        "patient_seq": patient_num,
        "ts":          datetime.now(timezone.utc).isoformat(),
    }

    leds.set_state(LEDState.CAPTURE)
    leds.set_bp_active(False)
    leds.set_spo2_active(False)
    leds.set_gluc_active(False)

    results = {"BP": None, "SpO2": None, "Glucose": None}
    pushed_partial_for = set()

    print(f"\n=== BP + SpO2 + Glucose (trigger: {trigger_kind}) ===")

    trigger_task = asyncio.create_task(
        _SESSION_CLASSES[trigger_kind](leds=leds).run(trigger_device)
    )
    task_to_kind = {trigger_task: trigger_kind}

    other_kinds = [k for k in ("BP", "SpO2", "Glucose") if k != trigger_kind]
    other_scan_tasks = {
        k: asyncio.create_task(
            scan_for_specific_device(k, _SESSION_TIMEOUTS[trigger_kind] + CONNECT_TIMEOUT + 5, leds=leds)
        )
        for k in other_kinds
    }
    other_run_tasks = {k: None for k in other_kinds}

    pending_tasks = {trigger_task, *other_scan_tasks.values()}

    while pending_tasks:
        done, pending_tasks = await asyncio.wait(
            pending_tasks, timeout=0.2, return_when=asyncio.FIRST_COMPLETED
        )

        for task in done:
            if task in task_to_kind:
                kind = task_to_kind[task]
                try:
                    results[kind] = task.result()
                except Exception as e:
                    print(f"  [{kind}] Task failed: {type(e).__name__}: {e}")
                    results[kind] = None

                if results[kind] and kind not in pushed_partial_for:
                    await push_partial(
                        record_base,
                        bp=results["BP"],
                        spo2=results["SpO2"],
                        glucose=results["Glucose"],
                        temp=None,
                        partial=True
                    )
                    pushed_partial_for.add(kind)

            else:
                scan_kind = None
                for k, scan_task in other_scan_tasks.items():
                    if scan_task is task:
                        scan_kind = k
                        break

                if scan_kind is None:
                    continue

                try:
                    dev = task.result()
                except Exception as e:
                    print(f"  [{scan_kind}] Scan task failed: {type(e).__name__}: {e}")
                    dev = None

                if dev and other_run_tasks[scan_kind] is None:
                    run_task = asyncio.create_task(_SESSION_CLASSES[scan_kind](leds=leds).run(dev))
                    other_run_tasks[scan_kind] = run_task
                    task_to_kind[run_task] = scan_kind
                    pending_tasks.add(run_task)

    for k in other_kinds:
        if results[k] is None and other_run_tasks[k] is None:
            print(f"  [Flow] {k} not found before primary window; waiting {POST_PRIMARY_FALLBACK_SCAN_SECS}s more.")
            dev = await scan_for_specific_device(k, POST_PRIMARY_FALLBACK_SCAN_SECS, leds=leds)
            if dev:
                try:
                    results[k] = await _SESSION_CLASSES[k](leds=leds).run(dev)
                    if results[k] and k not in pushed_partial_for:
                        await push_partial(
                            record_base,
                            bp=results["BP"],
                            spo2=results["SpO2"],
                            glucose=results["Glucose"],
                            temp=None,
                            partial=True
                        )
                        pushed_partial_for.add(k)
                except Exception as e:
                    print(f"  [{k}] Fallback run failed: {type(e).__name__}: {e}")

    print("\n=== Temperature ===")
    temp_result = await temp_sensor.read_average()

    print("\n=== Video ===")
    await record_video(patient_num, leds)

    print("\n=== Final Push ===")
    pushed_ok = await push_partial(
        record_base, bp=results["BP"], spo2=results["SpO2"],
        glucose=results["Glucose"], temp=temp_result, partial=False
    )

    session_ended_at = datetime.now()
    log_session_csv_row(
        patient_num, session_started_at, session_ended_at, trigger_kind,
        results["BP"], results["SpO2"], results["Glucose"], temp_result, pushed_ok
    )

    leds.set_state(LEDState.POST_FLOW)
    print(f"\n  [Lockout] Post-flow lockout for up to {LOCKOUT_SECS}s "
          f"(or until clearvitals signal).")

    skip_event   = asyncio.Event()
    poll_task    = asyncio.create_task(poll_for_clearvitals(skip_event))
    lockout_task = asyncio.create_task(asyncio.sleep(LOCKOUT_SECS))

    done, pending = await asyncio.wait(
        [poll_task, lockout_task], return_when=asyncio.FIRST_COMPLETED
    )
    for t in pending:
        t.cancel()
        try:
            await t
        except asyncio.CancelledError:
            pass

    leds.set_state(LEDState.WAIT_BP)
    log_session_divider()
    print(f"  [Lockout] Ended. Ready for next patient.\n")

# ---------------------------------------------------------------------------
# Main loop
# ---------------------------------------------------------------------------

async def main():
    leds        = LEDController()
    temp_sensor = TempSensor()
    patient_num = 0

    led_task = asyncio.create_task(leds.run())
    leds.set_state(LEDState.WAIT_BP)

    print("\n" + "=" * 60)
    print("  O-Health Vitals Kiosk — BP + SpO2 + Glucose + Temp Edition")
    print("=" * 60)

    await drain_spool()

    try:
        while True:
            trigger_kind, trigger_device = await wait_for_patient_device()
            patient_num += 1
            await run_patient_capture(
                patient_num, trigger_kind, trigger_device, temp_sensor, leds
            )
    except KeyboardInterrupt:
        print("\n  Shutdown requested.")
    finally:
        leds.shutdown()
        led_task.cancel()
        try:
            await led_task
        except asyncio.CancelledError:
            pass
        _console_log_fh.close()
        print("  Goodbye.")

if __name__ == "__main__":
    asyncio.run(main())
