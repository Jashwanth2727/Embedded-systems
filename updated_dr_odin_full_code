# ---------------------------------------------------------------------------

def _spo2_valid(spo2, pr):
    return 50 <= spo2 <= 100 and 30 <= pr <= 250

def _bluetoothctl_connect_spo2():
    print("  [SpO2] Connecting via bluetoothctl...")
    child = pexpect.spawn("bluetoothctl", encoding="utf-8", timeout=5)
    time.sleep(0.5)

    child.sendline(f"select {SPO2_ADAPTER_MAC}")
    time.sleep(0.3)

    child.sendline("scan on")
    time.sleep(5)

    child.sendline(f"trust {SPO2_ALLOWED_MAC}")
    time.sleep(0.5)

    child.sendline(f"connect {SPO2_ALLOWED_MAC}")

    try:
        child.expect("ServicesResolved: yes", timeout=20)
        print("  [SpO2] CONNECTED via bluetoothctl ✓")
        return child
    except pexpect.TIMEOUT:
        print("  [SpO2] Connection failed via bluetoothctl")
        try:
            child.sendline("quit")
            child.close()
        except Exception:
            pass
        return None

async def capture_spo2_new(adapter_lock=None) -> dict:
    lock = adapter_lock or _ble_adapter_lock
    result = {"spo2": None, "pr": None, "pi": None}
    stable_buf = []
    done_event = asyncio.Event()
    btctl_child = None
    bus = None

    async with lock:
        btctl_child = await asyncio.to_thread(_bluetoothctl_connect_spo2)
        if btctl_child is None:
            return result

        await asyncio.sleep(2)
        print("  [SpO2] Subscribing via D-Bus...")

        try:
            bus = await MessageBus(bus_type=BusType.SYSTEM).connect()

            def on_signal(msg):
                if msg.message_type != MessageType.SIGNAL:
                    return
                if msg.member != "PropertiesChanged":
                    return
                if SPO2_CHAR_PATH not in msg.path:
                    return

                changed = msg.body[1]
                if not isinstance(changed, dict) or "Value" not in changed:
                    return

                val = changed["Value"]
                data = bytes(val.value if isinstance(val, Variant) else val)

                if len(data) < 4 or data[0] != 0x81:
                    return

                spo2 = data[1]
                pr   = data[2]
                pi   = round(data[3] / 10, 1)

                if not _spo2_valid(spo2, pr):
                    stable_buf.clear()
                    return

                print(f"  [SpO2] SpO2={spo2}% PR={pr}bpm PI={pi}%")
                stable_buf.append((spo2, pr))
                if len(stable_buf) > SPO2_STABLE_COUNT:
                    stable_buf.pop(0)

                if len(stable_buf) == SPO2_STABLE_COUNT and len(set(stable_buf)) == 1:
                    result.update({"spo2": spo2, "pr": pr, "pi": pi})
                    print("  [SpO2] Stable reading!")
                    done_event.set()

            bus.add_message_handler(on_signal)

            await bus.call(Message(
                destination="org.freedesktop.DBus",
                path="/org/freedesktop/DBus",
                interface="org.freedesktop.DBus",
                member="AddMatch",
                signature="s",
                body=[
                    f"type='signal',sender='org.bluez',"
                    f"interface='org.freedesktop.DBus.Properties',"
                    f"member='PropertiesChanged',"
                    f"path='{SPO2_CHAR_PATH}'"
                ]
            ))
            print("  [SpO2] D-Bus match rule added")

            char_intro = await bus.introspect("org.bluez", SPO2_CHAR_PATH)
            char_obj = bus.get_proxy_object("org.bluez", SPO2_CHAR_PATH, char_intro)
            char_gatt = char_obj.get_interface("org.bluez.GattCharacteristic1")

            await char_gatt.call_start_notify()
            print(f"  [SpO2] StartNotify called. Insert finger. ({SPO2_MEASURE_TIMEOUT}s timeout)")

            try:
                await asyncio.wait_for(done_event.wait(), timeout=SPO2_MEASURE_TIMEOUT)
            except asyncio.TimeoutError:
                print(f"  [SpO2] ⚠ Measurement timed out after {SPO2_MEASURE_TIMEOUT}s")
            finally:
                try:
                    await char_gatt.call_stop_notify()
                except Exception:
                    pass

        except Exception as e:
            print(f"  [SpO2] D-Bus error: {type(e).__name__}: {e}")
        finally:
            if bus:
                try:
                    bus.disconnect()
                except Exception:
                    pass
            if btctl_child:
                try:
                    btctl_child.sendline(f"disconnect {SPO2_ALLOWED_MAC}")
                    time.sleep(0.5)
                    btctl_child.sendline("quit")
                    btctl_child.close()
                except Exception:
                    pass

    return result

class SpO2Session:
    def __init__(self, warmup_frames=1, leds=None):
        self.leds = leds

    async def run(self, device=None):
        if self.leds:
            self.leds.set_spo2_active(True)
        try:
            result = await capture_spo2_new()
            if result["spo2"] is None:
                print("  [SpO2] No stable reading captured.")
                return None
            return result
        except Exception as e:
            print(f"  [SpO2] Connection/measurement failed: {type(e).__name__}: {e}")
            return None
        finally:
            if self.leds:
                self.leds.set_spo2_active(False)

# ---------------------------------------------------------------------------
# Temperature sensor — TR-FR400 BLE Thermometer
# ---------------------------------------------------------------------------

class TempSensor:
    def __init__(self):
        self._celsius = None
        self._done    = asyncio.Event()

    def _on_notify(self, _handle, data: bytearray):
        if self._done.is_set():
            return
        if len(data) == 5 and data[0] == 0xAA and data[1] == 0x33:
            try:
                raw_value     = int.from_bytes(data[2:4], byteorder="big", signed=False)
                self._celsius = raw_value / 100.0
                print(f"  [Temp BLE raw] {' '.join(f'{b:02X}' for b in data)}")
                self._done.set()
            except Exception as e:
                print(f"  [Temp BLE parse error] {e}")

    async def _find_device(self):
        print(f"  [Temp] Trying known MAC {TEMP_ALLOWED_MAC} first...")
        device = await BleakScanner.find_device_by_address(TEMP_ALLOWED_MAC, timeout=5)
        if not device:
            print("  [Temp] MAC not cached — scanning for thermometer by name...")
            devices = await BleakScanner.discover(timeout=10)
            for d in devices:
                if d.name and any(h in d.name.upper() for h in TEMP_NAME_HINTS):
                    device = d
                    print(f"  [Temp] Found by name: {d.name} @ {d.address}")
                    break
        return device

    async def read_average(self):
        print(f"  [Temp] Waiting {TEMP_WAIT_AFTER_SPO2}s before BLE thermometer scan...")
        await asyncio.sleep(TEMP_WAIT_AFTER_SPO2)

        self._celsius = None
        self._done.clear()

        device = await self._find_device()
        if not device:
            print("  [Temp] ✗ Thermometer not found — press measure button to wake BLE.")
            return None

        print(f"  [Temp] Connecting to {device.name or device.address}...")
        try:
            async with BleakClient(device, timeout=TEMP_BLE_CONNECT_TIMEOUT) as client:
                print("  [Temp] Connected ✓  Subscribing to FFF3...")
                await client.start_notify(
                    TEMP_NOTIFY_UUID,
                    self._on_notify,
                    bluez=BlueZNotifyArgs(use_start_notify=True),
                )
                print(f"  [Temp] Waiting up to {TEMP_BLE_MEASURE_TIMEOUT}s — take a forehead measurement NOW...")
                try:
                    await asyncio.wait_for(self._done.wait(), timeout=TEMP_BLE_MEASURE_TIMEOUT)
                except asyncio.TimeoutError:
                    print("  [Temp] ⚠ Timeout — no packet received.")
                finally:
                    try:
                        await client.stop_notify(TEMP_NOTIFY_UUID)
                    except Exception:
                        pass
        except Exception as e:
            print(f"  [Temp] BLE connection/measurement failed: {type(e).__name__}: {e}")
            return None

        if self._celsius is None:
            return None

        celsius    = self._celsius
        fahrenheit = round(celsius * 9.0 / 5.0 + 32.0, 2)

        print(f"  ✓ Temp: {celsius:.2f}°C  ({fahrenheit:.2f}°F)  [ble_direct]")
        return {
            "ambient_c":      None,
            "object_c":       fahrenheit,
            "object_c_raw":   fahrenheit,
            "display_source": "ble_direct",
            "samples":        1,
        }

