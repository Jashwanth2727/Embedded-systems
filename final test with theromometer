# Main loop
# ============================================================
async def main():
    print(f">>> O-Health Kiosk: {KIOSK_ID} <<<")
    print(f"Backend: {BACKEND_URL}")
    print(f"Push retry: {PUSH_RETRIES} retries at {PUSH_RETRY_DELAY}s intervals "
          f"(total {1 + PUSH_RETRIES} attempts), then spool to disk")
    print(f"Temp display: raw if >= {TEMP_DISPLAY_THRESHOLD}°F, else synthetic "
          f"in [{TEMP_DISPLAY_RANGE_LOW}, {TEMP_DISPLAY_RANGE_HIGH}]°F")
    print(f"Flow: STEP1 BP -> STEP2 SpO2 -> STEP3 BLE Temp (Fallback: I2C) -> Push")
    print(f"      -> HARD {LOCKOUT_SECS}s LOCKOUT (BP detection ignored)")
    print(f"      -> wait for next BP power-on -> next patient\n")

    print("Initializing backup temperature sensor...")
    backup_temp_sensor = BackupTempSensor()

    print("Initializing LEDs...")
    leds = LEDController()
    led_task = asyncio.create_task(leds.run())

    drain_spool()

    patient = 0

    try:
        while True:
            patient += 1
            try:
                leds.set_state(LEDState.BP)
                bp_device = await wait_for_bp_powered_on()

                await run_patient_capture(patient, bp_device, backup_temp_sensor, leds)

                print(f"\n>>> POST-FLOW LOCKOUT — {LOCKOUT_SECS}s mandatory wait <<<")
                leds.set_state(LEDState.POST_FLOW)
                await asyncio.sleep(LOCKOUT_SECS)
                print(f">>> Lockout complete. Ready for next patient. <<<")

            except Exception as e:
                print(f"[!] Patient {patient} flow crashed: {type(e).__name__}: {e}")
                leds.set_state(LEDState.ERROR)
                await asyncio.sleep(5)

            print(f"\n--- Patient {patient} complete. ---")
    finally:
        leds.shutdown()
        led_task.cancel()

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        print("\nStopped by user.")
