_bg_tasks = set()

def _track(coro):
    task = asyncio.create_task(coro)
    _bg_tasks.add(task)
    task.add_done_callback(_bg_tasks.discard)
    return task

async def _quick_disconnect(client):
    try:
        await asyncio.wait_for(client.disconnect(), timeout=1.5)
    except Exception:
        pass

# ============================================================
# LED CONTROLLER
# ============================================================
LED_COUNT  = 19
LED_PIN    = 18
BRIGHTNESS = 0.5

LED_BP     = [0, 1, 2, 3]
LED_MIC    = [4, 5]
LED_SPO2   = [6, 7]
LED_GLUC   = [8]
LED_LOGO   = [9, 10, 11, 12]
LED_CAMERA = [13, 14, 15, 16, 17, 18]

def rgb_raw(r, g, b):
    return ((r & 0xFF) << 16) | ((g & 0xFF) << 8) | (b & 0xFF)

def rgb(r, g, b):
    return rgb_raw(int(r * BRIGHTNESS), int(g * BRIGHTNESS), int(b * BRIGHTNESS))

GREEN = rgb(0, 255, 0)
WHITE = rgb(255, 255, 255)
RED   = rgb(255, 0, 0)
OFF   = rgb_raw(0, 0, 0)

BREATH_FADE_STEPS = 25
BREATH_FADE_DELAY = 0.04
BREATH_HOLD_SECS  = 0.5

class LEDState(Enum):
    OFF       = "off"
    BP        = "bp"
    SPO2      = "spo2"
    POST_FLOW = "post_flow"
    ERROR     = "error"

class LEDController:
    def __init__(self):
        self.strip = None
        self.state = LEDState.OFF
        self._state_started = time.monotonic()
        self._stop = False
        if not HAS_LEDS:
            return
        try:
            self.strip = PixelStrip(LED_COUNT, LED_PIN)
            self.strip.begin()
            self._all_off()
            print(f"  ✓ LEDs initialized ({LED_COUNT} pixels on GPIO{LED_PIN}, "
                  f"brightness={int(BRIGHTNESS*100)}%)")
        except Exception as e:
            msg = f"{type(e).__name__}: {e}"
            print(f"  [warn] LED init failed: {msg}")
            if "permission" in msg.lower() or "denied" in msg.lower() or "mmap" in msg.lower():
                print(f"         Run with sudo: sudo python3 sensor_all.py")
            self.strip = None

    def _all_off(self):
        if not self.strip:
            return
        for i in range(LED_COUNT):
            self.strip.setPixelColor(i, OFF)
        self.strip.show()

    def _set_pixels(self, leds, color):
        if not self.strip:
            return
        for i in leds:
            self.strip.setPixelColor(i, color)

    def _show(self):
        if self.strip:
            self.strip.show()

    @staticmethod
    def _scale(color, factor):
        r = (color >> 16) & 0xFF
        g = (color >> 8) & 0xFF
        b = color & 0xFF
        return rgb_raw(int(r * factor), int(g * factor), int(b * factor))

    @staticmethod
    def _breath_factor(elapsed):
        cycle_len = 2 * (BREATH_FADE_STEPS * BREATH_FADE_DELAY) + 2 * BREATH_HOLD_SECS
        t = elapsed % cycle_len
        fade_dur = BREATH_FADE_STEPS * BREATH_FADE_DELAY
        if t < fade_dur:
            return t / fade_dur
        t -= fade_dur
        if t < BREATH_HOLD_SECS:
            return 1.0
        t -= BREATH_HOLD_SECS
        if t < fade_dur:
            return 1.0 - (t / fade_dur)
        return 0.0

    def set_state(self, new_state: LEDState):
        if self.state != new_state:
            print(f"  [LED] {self.state.value} -> {new_state.value}")
            self.state = new_state
            self._state_started = time.monotonic()

    async def run(self):
        if not self.strip:
            return
        try:
            while not self._stop:
                self._render()
                await asyncio.sleep(BREATH_FADE_DELAY)
        finally:
            self._all_off()

    def _render(self):
        if not self.strip:
            return
        elapsed = time.monotonic() - self._state_started
        for i in range(LED_COUNT):
            self.strip.setPixelColor(i, OFF)

        self._set_pixels(LED_LOGO, WHITE)
        self._set_pixels(LED_CAMERA, WHITE)

        st = self.state
        if st == LEDState.OFF:
            pass
        elif st == LEDState.BP:
            f = self._breath_factor(elapsed)
            self._set_pixels(LED_BP, self._scale(GREEN, f))
        elif st == LEDState.SPO2:
            f = self._breath_factor(elapsed)
            self._set_pixels(LED_SPO2, self._scale(GREEN, f))
        elif st == LEDState.POST_FLOW:
            if elapsed < GLUC_ON_SECS:
                self._set_pixels(LED_GLUC, GREEN)
            if elapsed < LOCKOUT_SECS:
                self._set_pixels(LED_MIC, GREEN)
        elif st == LEDState.ERROR:
            self._set_pixels(LED_BP + LED_MIC + LED_SPO2 + LED_GLUC, RED)

        self._show()

    def shutdown(self):
        self._stop = True
        if self.strip:
            self._all_off()

